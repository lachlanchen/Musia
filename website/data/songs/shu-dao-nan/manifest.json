  "timeline": {
    "unit": "seconds",
    "lines": [
      {
        "id": "l01",
        "start": 22.54,
        "end": 25.06,
        "text": "山高入云端"
      },
      {
        "id": "l02",
        "start": 25.06,
        "end": 26.96,
        "text": "古道挂天边"
      },
      {
        "id": "l03",
        "start": 26.96,
        "end": 28.56,
        "text": "风从秦川起"
      },
      {
        "id": "l04",
        "start": 28.56,
        "end": 30.32,
        "text": "吹过四万年"
      },
      {
        "id": "l05",
        "start": 30.32,
        "end": 32.44,
        "text": "石栈连天去"
      },
      {
        "id": "l06",
        "start": 32.44,
        "end": 34.26,
        "text": "回川卷狂澜"
      },
      {
        "id": "l07",
        "start": 34.26,
        "end": 36.22,
        "text": "黄鹤飞不过"
      },
      {
        "id": "l08",
        "start": 36.22,
        "end": 37.78,
        "text": "我仍向前"
      },
      {
        "id": "l09",
        "start": 38.52,
        "end": 40.16,
        "text": "青泥路盘盘"
      },
      {
        "id": "l10",
        "start": 40.16,
        "end": 41.92,
        "text": "百步绕千山"
      },
      {
        "id": "l11",
        "start": 41.92,
        "end": 43.16,
        "text": "抬头星辰近"
      },
      {
        "id": "l12",
        "start": 43.16,
        "end": 46.96,
        "text": "低头是深渊"
      },
      {
        "id": "l13",
        "start": 46.96,
        "end": 49.3,
        "text": "蜀道难"
      },
      {
        "id": "l14",
        "start": 50.16,
        "end": 53.06,
        "text": "难于上青天"
      },
      {
        "id": "l15",
        "start": 54.88,
        "end": 56.72,
        "text": "蜀道难"
      },
      {
        "id": "l16",
        "start": 61.14,
        "end": 63.46,
        "text": "悲鸟绕古木"
      },
      {
        "id": "l17",
        "start": 63.46,
        "end": 65.26,
        "text": "子规啼夜月"
      },
      {
        "id": "l18",
        "start": 65.26,
        "end": 67.22,
        "text": "问君何时还"
      },
      {
        "id": "l19",
        "start": 67.22,
        "end": 69.14,
        "text": "心已越峰巅"
      },
      {
        "id": "l20",
        "start": 69.14,
        "end": 71.04,
        "text": "剑阁高又险"
      },
      {
        "id": "l21",
        "start": 71.04,
        "end": 72.94,
        "text": "一夫守万关"
      },
      {
        "id": "l22",
        "start": 72.94,
        "end": 74.74,
        "text": "锦城虽云乐"
      },
      {
        "id": "l23",
        "start": 74.74,
        "end": 76.94,
        "text": "不如早回山"
      },
      {
        "id": "l24",
        "start": 77.52,
        "end": 79.38,
        "text": "蜀道难"
      },
      {
        "id": "l25",
        "start": 79.38,
        "end": 81.64,
        "text": "难于上青天"
      },
      {
        "id": "l26",
        "start": 81.64,
        "end": 85.26,
        "text": "侧身西望，心潮万千"
      },
      {
        "id": "l27",
        "start": 85.26,
        "end": 89.08,
        "text": "若能望见晴天"
      },
      {
        "id": "l28",
        "start": 89.08,
        "end": 93.86,
        "text": "走过险路，仍要见晴天"
      }
    ]
  },
