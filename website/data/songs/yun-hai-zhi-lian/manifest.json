  "timeline": {
    "unit": "seconds",
    "lines": [
      {
        "id": "l01",
        "start": 7.7,
        "end": 18.62,
        "text": "天蓝蓝，海蓝蓝，云在天地间"
      },
      {
        "id": "l02",
        "start": 19.78,
        "end": 23.1,
        "text": "想念像风一样"
      },
      {
        "id": "l03",
        "start": 23.78,
        "end": 27.9,
        "text": "依偎在你身边"
      },
      {
        "id": "l04",
        "start": 28.74,
        "end": 31.72,
        "text": "望着那么远"
      },
      {
        "id": "l05",
        "start": 32.78,
        "end": 36.14,
        "text": "却像在眼前"
      },
      {
        "id": "l06",
        "start": 36.78,
        "end": 47.8,
        "text": "慢慢，慢慢，穿过云海"
      },
      {
        "id": "l07",
        "start": 47.8,
        "end": 52.26,
        "text": "落进心里面"
      },
      {
        "id": "l08",
        "start": 53.77,
        "end": 58.34,
        "text": "我好想来到你身边"
      },
      {
        "id": "l09",
        "start": 59.18,
        "end": 62.92,
        "text": "看清你的容颜"
      },
      {
        "id": "l10",
        "start": 63.87,
        "end": 67.42,
        "text": "哪怕隔着山海万千"
      },
      {
        "id": "l11",
        "start": 68.78,
        "end": 73.06,
        "text": "也想与你相见"
      },
      {
        "id": "l12",
        "start": 74.3,
        "end": 76.98,
        "text": "似水流年"
      },
      {
        "id": "l13",
        "start": 78.34,
        "end": 80.96,
        "text": "时光轮转"
      },
      {
        "id": "l14",
        "start": 82.3,
        "end": 88.92,
        "text": "这一眼，越过千年不变"
      },
      {
        "id": "l15",
        "start": 88.92,
        "end": 92.52,
        "text": "云海之间"
      },
      {
