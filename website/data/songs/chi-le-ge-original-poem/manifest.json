        "id": "l04",
        "start": 21.37,
        "end": 26.83,
        "text": "天似秋露，露盖丝颜"
      },
      {
        "id": "l05",
        "start": 27.45,
        "end": 30.17,
        "text": "天苍苍，野茫茫"
      },
