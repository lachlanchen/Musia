    "lines": [
      {
        "id": "l01",
        "start": 19.94,
        "end": 27.68,
        "text": "君不见黄河之水天上来"
      },
      {
        "id": "l02",
        "start": 28.68,
        "end": 32.3,
        "text": "奔流到海不复回"
      },
      {
        "id": "l03",
        "start": 33.24,
        "end": 37.14,
        "text": "君不见高堂明镜悲白发"
      },
      {
        "id": "l04",
        "start": 37.14,
        "end": 40.6,
        "text": "朝如青丝暮成雪"
      },
      {
        "id": "l05",
        "start": 40.6,
        "end": 44.26,
        "text": "人生得意须尽欢"
      },
      {
        "id": "l06",
        "start": 44.26,
        "end": 48.22,
        "text": "莫使金樽空对月"
      },
      {
        "id": "l07",
        "start": 49.36,
        "end": 52.24,
        "text": "天生我材必有用"
      },
      {
        "id": "l08",
        "start": 52.24,
        "end": 55.68,
        "text": "莫使金樽空对月"
      },
      {
        "id": "l09",
        "start": 55.68,
        "end": 59.7,
        "text": "天生我材必有用"
      },
      {
        "id": "l10",
        "start": 59.7,
        "end": 63.4,
        "text": "千金散尽还复来"
      },
      {
        "id": "l11",
        "start": 64.04,
        "end": 67.2,
        "text": "烹羊宰牛且为乐"
      },
      {
        "id": "l12",
        "start": 67.8,
        "end": 71.12,
        "text": "会须一饮三百杯"
      },
      {
        "id": "l13",
        "start": 71.12,
        "end": 73.04,
        "text": "岑夫子"
      },
      {
        "id": "l14",
        "start": 73.9,
        "end": 79.08,
        "text": "丹丘生，将进酒，杯莫停"
      },
      {
        "id": "l15",
        "start": 83.7,
        "end": 88.36,
        "text": "将进酒，杯莫停"
      },
      {
        "id": "l16",
        "start": 90.66,
        "end": 93.12,
        "text": "与君歌一曲"
      },
      {
        "id": "l17",
        "start": 93.12,
        "end": 97.0,
        "text": "请君为我倾耳听"
      },
      {
        "id": "l18",
        "start": 98.0,
        "end": 101.5,
        "text": "钟鼓馔玉不足贵"
      },
      {
        "id": "l19",
        "start": 101.5,
        "end": 105.16,
        "text": "但愿长醉不愿醒"
      },
      {
        "id": "l20",
        "start": 105.16,
        "end": 108.86,
        "text": "古来圣贤皆寂寞"
      },
      {
        "id": "l21",
        "start": 108.86,
        "end": 112.86,
        "text": "惟有饮者留其名"
      },
      {
        "id": "l22",
        "start": 113.44,
        "end": 117.32,
        "text": "陈王昔时宴平乐"
      },
      {
        "id": "l23",
        "start": 117.32,
        "end": 121.64,
        "text": "陈王昔时宴平乐"
      },
      {
        "id": "l24",
        "start": 121.64,
        "end": 125.28,
        "text": "斗酒十千恣欢谑"
      },
      {
        "id": "l25",
        "start": 125.28,
        "end": 129.36,
        "text": "主人何为言少钱"
      },
      {
        "id": "l26",
        "start": 129.36,
        "end": 133.36,
        "text": "径须沽取对君酌"
      },
      {
        "id": "l27",
        "start": 133.36,
        "end": 139.2,
        "text": "五花马，千金裘"
      },
      {
        "id": "l28",
        "start": 153.36,
        "end": 157.48,
        "text": "五花马，千金裘"
      },
      {
        "id": "l29",
        "start": 162.12,
        "end": 166.2,
        "text": "呼儿将出换美酒"
      },
      {
        "id": "l30",
        "start": 169.18,
        "end": 174.94,
