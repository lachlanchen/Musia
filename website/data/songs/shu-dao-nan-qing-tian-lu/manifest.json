        "text": "云在脚边"
      },
      {
        "id": "l03",
        "start": 19.0,
        "end": 21.7,
        "text": "旧路弯弯"
      },
      {
        "id": "l04",
        "start": 21.7,
        "end": 24.36,
        "text": "看不见终点"
      },
      {
        "id": "l05",
        "start": 25.0,
        "end": 27.48,
        "text": "有人说别走"
      },
      {
        "id": "l06",
        "start": 27.48,
        "end": 30.7,
        "text": "前方太遥远"
      },
      {
        "id": "l07",
        "start": 30.7,
        "end": 36.62,
        "text": "我把害怕放进心里面"
      },
      {
        "id": "l08",
        "start": 49.52,
        "end": 52.1,
        "text": "夜鸟飞远"
      },
      {
        "id": "l09",
        "start": 52.1,
        "end": 54.92,
        "text": "月落桥边"
      },
      {
        "id": "l10",
        "start": 55.8,
        "end": 58.06,
        "text": "照我向云间"
      },
      {
        "id": "l11",
        "start": 59.1,
        "end": 61.06,
        "text": "不是不怕"
      },
      {
        "id": "l12",
        "start": 61.94,
        "end": 64.14,
        "text": "只想到天破"
      },
      {
        "id": "l13",
        "start": 64.7,
        "end": 67.24,
        "text": "路再难也要走"
      },
      {
        "id": "l14",
        "start": 67.78,
        "end": 70.26,
        "text": "眼中还有尽头"
      },
      {
        "id": "l15",
        "start": 70.26,
        "end": 73.7,
        "text": "心不要低头"
      },
      {
        "id": "l16",
        "start": 74.28,
        "end": 76.54,
        "text": "黑夜被风吹散"
      },
      {
        "id": "l17",
        "start": 76.54,
        "end": 79.76,
        "text": "梦越过山尽头"
