  "timeline": {
    "unit": "seconds",
    "lines": [
      {
        "id": "l01",
        "start": 16.02,
        "end": 19.96,
        "text": "不要分开，我的心里你还在"
      },
      {
        "id": "l02",
        "start": 20.32,
        "end": 23.1,
        "text": "微微琐事，落进心海"
      },
      {
        "id": "l03",
        "start": 23.1,
        "end": 26.26,
        "text": "一点一点，把我们推开"
      },
      {
        "id": "l04",
        "start": 29.02,
        "end": 32.18,
        "text": "你说爱还在，只是太疲惫"
      },
      {
        "id": "l05",
        "start": 32.18,
        "end": 35.1,
        "text": "我说别沉默，抱紧我一回"
      },
      {
        "id": "l06",
        "start": 36.52,
        "end": 38.92,
        "text": "会不会好点"
      },
      {
        "id": "l07",
        "start": 40.94,
        "end": 42.02,
        "text": "微微，微微"
      },
      {
        "id": "l08",
        "start": 42.96,
        "end": 45.32,
        "text": "我绕着你转"
      },
      {
        "id": "l09",
        "start": 45.32,
        "end": 48.3,
        "text": "半径越来越远"
      },
      {
        "id": "l10",
        "start": 48.3,
        "end": 51.18,
        "text": "角度还不肯散"
      },
      {
        "id": "l11",
        "start": 51.18,
        "end": 52.7,
        "text": "傅立叶变换"
      },
      {
        "id": "l12",
        "start": 52.7,
        "end": 53.44,
        "text": "拆开了思念"
      },
      {
        "id": "l13",
        "start": 53.44,
        "end": 57.02,
        "text": "每一个频率，都喊你一遍"
      },
      {
        "id": "l14",
        "start": 57.02,
        "end": 57.92,
        "text": "微微，微微"
      },
      {
        "id": "l15",
        "start": 61.78,
        "end": 67.29,
        "text": "最小的痛，也会成海"
      },
      {
        "id": "l16",
        "start": 69.69,
        "end": 74.23,
        "text": "你说爱还在，可是想分开"
      },
      {
        "id": "l17",
        "start": 75.17,
        "end": 79.47,
        "text": "我的心里，你还在"
      }
    ]
  },
