  "timeline": {
    "lines": [
      {
        "id": "l01",
        "start": 12.11,
        "end": 17.07,
        "text": "沙沙，沙沙，大海的沙"
      },
      {
        "id": "l02",
        "start": 18.03,
        "end": 24.35,
        "text": "沙漠的沙，沙漠的沙，数不尽它"
      },
      {
        "id": "l03",
        "start": 25.25,
        "end": 30.19,
        "text": "你牵着我，沿着浪花"
      },
      {
        "id": "l04",
        "start": 30.19,
        "end": 40.81,
        "text": "风吹到千叶海边，轻指楼兰姑娘面庞"
      },
      {
        "id": "l05",
        "start": 40.81,
        "end": 44.05,
        "text": "你笑着说，世界很大"
      },
      {
        "id": "l06",
        "start": 44.05,
        "end": 48.41,
        "text": "可此刻只装得下，我们俩"
      },
      {
        "id": "l07",
        "start": 55.99,
        "end": 58.47,
        "text": "夕阳落在肩上"
      },
      {
        "id": "l08",
        "start": 58.47,
        "end": 64.57,
        "text": "沙沙，沙沙，海浪说悄悄话"
      },
      {
        "id": "l09",
        "start": 64.57,
        "end": 70.37,
        "text": "沙沙，沙沙，太阳慢慢落下"
      }
    ]
  },
