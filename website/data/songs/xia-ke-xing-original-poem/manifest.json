    "lines": [
      {
        "id": "l01",
        "start": 20.0,
        "end": 22.72,
        "text": "赵客缦胡缨"
      },
      {
        "id": "l02",
        "start": 22.72,
        "end": 25.18,
        "text": "赵客缦胡缨"
      },
      {
        "id": "l03",
        "start": 25.18,
        "end": 27.24,
        "text": "吴钩霜雪明"
      },
      {
        "id": "l04",
        "start": 28.56,
        "end": 30.35,
        "text": "银鞍照白马"
      },
      {
        "id": "l05",
        "start": 30.35,
        "end": 32.18,
        "text": "飒沓如流星"
      },
      {
        "id": "l06",
        "start": 33.14,
        "end": 34.96,
        "text": "十步杀一人"
      },
      {
        "id": "l07",
        "start": 34.96,
        "end": 37.14,
        "text": "事了拂衣去"
      },
      {
        "id": "l08",
        "start": 37.14,
        "end": 40.0,
        "text": "深藏身与名"
      },
      {
        "id": "l09",
        "start": 43.64,
        "end": 45.82,
        "text": "脱剑膝前横"
      },
      {
        "id": "l10",
        "start": 46.62,
        "end": 48.92,
        "text": "将炙啖朱亥"
      },
      {
        "id": "l11",
        "start": 48.92,
        "end": 51.34,
        "text": "持觞劝侯嬴"
      },
      {
        "id": "l12",
        "start": 51.34,
        "end": 53.64,
        "text": "持觞劝侯嬴"
      },
      {
        "id": "l13",
        "start": 56.26,
        "end": 59.2,
        "text": "三杯吐然诺"
      },
      {
        "id": "l14",
        "start": 59.2,
        "end": 61.82,
        "text": "五岳倒为轻"
      },
      {
        "id": "l15",
        "start": 64.28,
        "end": 66.55,
        "text": "眼花耳热后"
      },
      {
        "id": "l16",
        "start": 66.55,
        "end": 68.86,
        "text": "意气素霓生"
      },
      {
        "id": "l17",
        "start": 68.86,
        "end": 71.34,
        "text": "救赵挥金槌"
      },
      {
        "id": "l18",
        "start": 71.34,
        "end": 75.2,
        "text": "邯郸先震惊"
      },
      {
        "id": "l19",
        "start": 76.2,
        "end": 78.3,
        "text": "千秋二壮士"
      },
      {
        "id": "l20",
        "start": 78.3,
        "end": 80.5,
        "text": "烜赫大梁城"
      },
      {
        "id": "l21",
        "start": 80.5,
        "end": 83.36,
        "text": "纵死侠骨香"
      },
      {
        "id": "l22",
        "start": 83.36,
        "end": 86.2,
        "text": "不惭世上英"
      },
      {
        "id": "l23",
        "start": 88.8,
        "end": 91.14,
        "text": "谁能说孤侠"
      },
      {
        "id": "l24",
        "start": 91.14,
        "end": 93.96,
        "text": "白首太仙境"
      }
    ]
  },
