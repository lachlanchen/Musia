  "timeline": {
    "unit": "seconds",
    "lines": [
      {
        "id": "l01",
        "start": 12.18,
        "end": 17.6,
        "text": "海上烟涛，远道难求"
      },
      {
        "id": "l02",
        "start": 17.6,
        "end": 23.0,
        "text": "越人说天姥，云霞明灭在心头"
      },
      {
        "id": "l03",
        "start": 23.3,
        "end": 29.3,
        "text": "青云梯上，海日初升"
      },
      {
        "id": "l04",
        "start": 29.86,
        "end": 35.3,
        "text": "天鸡一声，千岩都回声"
      },
      {
        "id": "l05",
        "start": 35.3,
        "end": 38.3,
        "text": "梦过天姥，梦到云深处"
      },
      {
        "id": "l06",
        "start": 38.82,
        "end": 43.28,
        "text": "霓为风马，万山为我开路"
      },
      {
        "id": "l07",
        "start": 43.28,
        "end": 46.58,
        "text": "梦过天姥，醒来仍不负"
      },
      {
        "id": "l08",
        "start": 46.58,
        "end": 49.34,
        "text": "安能低眉，安能折腰"
      },
      {
        "id": "l09",
        "start": 49.34,
        "end": 52.68,
        "text": "换我开心颜"
      },
      {
        "id": "l10",
        "start": 54.74,
        "end": 57.9,
        "text": "熊咆龙吟，震动岩泉"
      },
      {
        "id": "l11",
        "start": 57.9,
        "end": 60.48,
        "text": "云青青欲雨"
      },
      {
        "id": "l12",
        "start": 60.48,
        "end": 63.5,
        "text": "水烟漫过山巅"
      },
      {
        "id": "l13",
        "start": 63.5,
        "end": 66.02,
        "text": "列缺霹雳，石门忽然开"
      },
      {
        "id": "l14",
        "start": 66.02,
        "end": 69.18,
        "text": "日月照金台，仙人纷纷来"
      },
      {
        "id": "l15",
        "start": 69.18,
        "end": 73.12,
        "text": "忽然魂动，长叹醒来"
      },
      {
        "id": "l16",
        "start": 73.12,
        "end": 78.74,
        "text": "枕席还在，烟霞已不在"
      },
      {
        "id": "l17",
        "start": 78.74,
        "end": 82.86,
        "text": "梦过天姥，梦到天地外"
      },
      {
        "id": "l18",
        "start": 82.86,
        "end": 86.16,
        "text": "世间万事，东流入海"
      },
      {
        "id": "l19",
        "start": 86.16,
        "end": 88.36,
        "text": "我心不尘埃"
      },
      {
        "id": "l20",
        "start": 88.36,
        "end": 91.74,
        "text": "梦过天姥，白鹿青崖在"
      },
      {
        "id": "l21",
        "start": 91.74,
        "end": 94.22,
        "text": "安能低眉，安能折腰"
      },
      {
        "id": "l22",
        "start": 94.22,
        "end": 97.1,
        "text": "让我不得开心颜"
      }
    ]
  },
