  "timeline": {
    "unit": "seconds",
    "lines": [
      {
        "id": "l01",
        "start": 13.74,
        "end": 15.78,
        "text": "黄河从天来"
      },
      {
        "id": "l02",
        "start": 15.78,
        "end": 17.74,
        "text": "月光落满台"
      },
      {
        "id": "l03",
        "start": 17.74,
        "end": 19.28,
        "text": "一杯敬风雪"
      },
      {
        "id": "l04",
        "start": 19.28,
        "end": 20.82,
        "text": "一杯敬尘埃"
      },
      {
        "id": "l05",
        "start": 20.82,
        "end": 22.38,
        "text": "白发照明镜"
      },
      {
        "id": "l06",
        "start": 22.38,
        "end": 23.94,
        "text": "少年还在怀"
      },
      {
        "id": "l07",
        "start": 23.94,
        "end": 26.17,
        "text": "别问归不归"
      },
      {
        "id": "l08",
        "start": 26.17,
        "end": 28.4,
        "text": "今夜花正开"
      },
      {
        "id": "l09",
        "start": 28.4,
        "end": 31.41,
        "text": "人生有几回"
      },
      {
        "id": "l10",
        "start": 31.41,
        "end": 34.42,
        "text": "敢把梦点燃"
      },
      {
        "id": "l11",
        "start": 34.42,
        "end": 37.13,
        "text": "千金散尽后"
      },
      {
        "id": "l12",
        "start": 37.13,
        "end": 39.84,
        "text": "我仍向云山"
      },
      {
        "id": "l13",
        "start": 39.84,
        "end": 42.7,
        "text": "将进酒，杯莫停"
      },
      {
        "id": "l14",
        "start": 42.7,
        "end": 46.48,
        "text": "让长风吹醒我的心"
      },
      {
        "id": "l15",
        "start": 46.48,
        "end": 48.96,
        "text": "天生我材必有用"
      },
      {
        "id": "l16",
        "start": 48.96,
        "end": 53.38,
        "text": "一身孤勇也多情"
      },
      {
        "id": "l17",
        "start": 53.38,
        "end": 56.44,
        "text": "钟鼓不必贵"
      },
      {
        "id": "l18",
        "start": 56.44,
        "end": 59.68,
        "text": "明月最慷慨"
      },
      {
        "id": "l19",
        "start": 59.68,
        "end": 61.4,
        "text": "圣贤多寂寞"
      },
      {
        "id": "l20",
        "start": 61.4,
        "end": 65.86,
        "text": "饮者留名来"
      },
      {
        "id": "l21",
        "start": 65.86,
        "end": 68.44,
        "text": "若天地问我"
      },
      {
        "id": "l22",
        "start": 69.16,
        "end": 71.94,
        "text": "为何还不醒"
      },
      {
        "id": "l23",
        "start": 71.94,
        "end": 74.28,
        "text": "我笑说人间"
      },
      {
        "id": "l24",
        "start": 74.28,
        "end": 77.6,
        "text": "有你便有星"
      },
      {
        "id": "l25",
        "start": 77.6,
        "end": 80.44,
        "text": "将进酒，杯莫停"
      },
      {
        "id": "l26",
        "start": 80.44,
        "end": 83.9,
        "text": "让黄河奔过我胸襟"
      },
      {
        "id": "l27",
        "start": 83.9,
        "end": 86.3,
        "text": "天生我材必有用"
      },
      {
        "id": "l28",
        "start": 86.3,
        "end": 89.1,
        "text": "千回百转"
      },
      {
        "id": "l29",
        "start": 89.1,
        "end": 93.48,
        "text": "仍相信"
      },
      {
        "id": "l30",
        "start": 93.48,
        "end": 96.46,
        "text": "杯莫停"
      },
      {
        "id": "l31",
        "start": 96.46,
        "end": 99.44,
        "text": "杯莫停"
      },
      {
        "id": "l32",
        "start": 99.44,
        "end": 102.91,
        "text": "愿此心"
      },
      {
        "id": "l33",
        "start": 102.91,
        "end": 106.38,
        "text": "永不平"
      }
    ]
