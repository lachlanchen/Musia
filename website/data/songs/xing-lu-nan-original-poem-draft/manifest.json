    "lines": [
      {
        "id": "l01",
        "start": 2.74,
        "end": 7.4,
        "text": "长风破浪会有时"
      },
      {
        "id": "l02",
        "start": 8.66,
        "end": 13.46,
        "text": "直挂云帆济沧海"
      },
      {
        "id": "l03",
        "start": 14.4,
        "end": 17.6,
        "text": "行路难"
      },
      {
        "id": "l04",
        "start": 17.6,
        "end": 20.8,
        "text": "行路难"
      },
      {
        "id": "l05",
        "start": 20.8,
        "end": 24.3,
        "text": "多歧路"
      },
      {
        "id": "l06",
        "start": 24.3,
        "end": 28.6,
        "text": "今安在"
      },
      {
        "id": "l07",
        "start": 31.0,
        "end": 36.4,
        "text": "金樽清酒斗十千"
      },
      {
        "id": "l08",
        "start": 36.4,
        "end": 42.7,
        "text": "玉盘珍羞直万钱"
      },
      {
        "id": "l09",
        "start": 42.7,
        "end": 48.1,
        "text": "停杯投箸不能食"
      },
      {
        "id": "l10",
        "start": 48.1,
        "end": 53.8,
        "text": "拔剑四顾心茫然"
      },
      {
        "id": "l11",
        "start": 53.8,
        "end": 59.0,
        "text": "欲渡黄河冰塞川"
      },
      {
        "id": "l12",
        "start": 59.0,
        "end": 65.0,
        "text": "将登太行雪满山"
      },
      {
        "id": "l13",
        "start": 65.0,
        "end": 70.2,
        "text": "闲来垂钓碧溪上"
      },
      {
        "id": "l14",
        "start": 70.2,
        "end": 76.0,
        "text": "忽复乘舟梦日边"
      },
      {
        "id": "l15",
        "start": 76.0,
        "end": 79.4,
        "text": "行路难"
      },
      {
        "id": "l16",
        "start": 79.4,
